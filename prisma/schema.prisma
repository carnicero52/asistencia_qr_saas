generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id               String         @id @default(cuid())
  slug             String         @unique
  nombre           String
  descripcion      String?
  logo             String?
  logoUrl          String?
  colorPrimario    String         @default("#10B981")
  colorSecundario  String         @default("#6366F1")
  plan             String         @default("gratis")
  activo           Boolean        @default(true)
  fechaVencimiento DateTime?
  zonaHoraria      String         @default("America/Mexico_City")
  idioma           String         @default("es")
  emailContacto    String?
  telefono         String?
  maxUsuarios      Int            @default(5)
  maxPersonas      Int            @default(100)
  maxGrupos        Int            @default(10)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  actividades      Actividad[]
  configuracion    Configuracion?
  grupos           Grupo[]
  personas         Persona[]
  usuarios         Usuario[]

  @@index([slug])
  @@index([activo])
  @@index([plan])
}

model Usuario {
  id                     String       @id @default(cuid())
  username               String
  password               String
  nombre                 String
  email                  String?
  rol                    String       @default("usuario")
  activo                 Boolean      @default(true)
  avatar                 String?
  tenantId               String
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  asistenciasRegistradas Asistencia[] @relation("RegistradorAsistencia")
  sesiones               Sesion[]
  tenant                 Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, username])
  @@index([tenantId])
  @@index([activo])
}

model Sesion {
  id        String   @id @default(cuid())
  usuarioId String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([token])
}

model Grupo {
  id          String    @id @default(cuid())
  nombre      String
  descripcion String?
  color       String    @default("#10B981")
  activo      Boolean   @default(true)
  tenantId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  personas    Persona[]

  @@index([tenantId])
  @@index([activo])
}

model Persona {
  id          String       @id @default(cuid())
  codigo      String
  nombre      String
  apellido    String
  email       String?
  telefono    String?
  foto        String?
  codigoQr    String       @unique
  activo      Boolean      @default(true)
  tenantId    String
  grupoId     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  asistencias Asistencia[]
  grupo       Grupo?       @relation(fields: [grupoId], references: [id])
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, codigo])
  @@index([tenantId])
  @@index([grupoId])
  @@index([activo])
  @@index([codigo])
}

model Asistencia {
  id            String   @id @default(cuid())
  personaId     String
  registradoPor String?
  tipo          String   @default("entrada")
  fecha         DateTime @default(now())
  hora          String
  metodo        String   @default("qr")
  notas         String?
  latitud       Float?
  longitud      Float?
  createdAt     DateTime @default(now())
  persona       Persona  @relation(fields: [personaId], references: [id], onDelete: Cascade)
  registrador   Usuario? @relation("RegistradorAsistencia", fields: [registradoPor], references: [id])

  @@index([personaId])
  @@index([fecha])
  @@index([tipo])
}

model Configuracion {
  id                    String   @id @default("default")
  tenantId              String   @unique
  nombreInstitucion     String   @default("Mi Institución")
  toleranciaMinutos     Int      @default(15)
  emailNotificaciones   String?
  activarNotificaciones Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Actividad {
  id        String   @id @default(cuid())
  tenantId  String
  usuarioId String?
  accion    String
  entidad   String
  entidadId String?
  detalles  String?
  ip        String?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([entidad])
  @@index([createdAt])
}

model SuperAdmin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  nombre    String
  email     String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
